# Environment Configuration for Standup App
# Copy this file to .env and update the values as needed

# Authentication credentials
AUTH_USERNAME=
AUTH_PASSWORD=

# Secret key for HMAC token signing (keep this secure!)
FLASK_SECRET_KEY=
# CSRF token lifetime in seconds (1 hour = 3600)
WTF_CSRF_TIME_LIMIT=3600

# Path to the standups data file
STANDUPS_FILE=/app/data/Standups.txt

# Discord webhook URL for security notifications (optional)
DISCORD_WEBHOOK_URL=

# Application port
SERVER_PORT=5555
