# Environment Configuration for Standup App
# Copy this file to .env and update the values as needed

# Application Mode (PROD or QA - case insensitive, default: PROD)
# QA mode disables 2FA and Discord notifications for testing
MODE=PROD

# Authentication credentials
AUTH_USERNAME=
AUTH_PASSWORD=

# Secret key for HMAC token signing (keep this secure!)
FLASK_SECRET_KEY=
# CSRF token lifetime in seconds (1 hour = 3600)
WTF_CSRF_TIME_LIMIT=3600

# Session timeout in seconds (default: 900 = 15 minutes)
SESSION_TIMEOUT_SECONDS=900

# Path to the standups data file
STANDUPS_FILE=/app/data/Standups.txt

# Discord webhook URL for security notifications (optional)
DISCORD_WEBHOOK_URL=

# Uptime threshold in milliseconds (default: 604800000 = 7 days)
APP_UPTIME_MAX_MILLIS=604800000

# Application port
SERVER_PORT=5555
